opt_out_usage

default_platform(:ios)

platform :ios do
  desc "Upload screenshots and metadata to App Store Connect"
  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    version = ENV["ASC_APP_VERSION"]
    UI.user_error!("Set ASC_APP_VERSION (run: eval \"$(python3 scripts/asc-ensure-draft-version.py | grep '^export ')\")") unless version && !version.empty?

    # Guard: with overwrite_screenshots, uploading from an EMPTY screenshots
    # dir would wipe the live App Store screenshots. Only touch screenshots when
    # we actually have some to upload; otherwise push text metadata only.
    screenshots_dir = File.expand_path("screenshots", __dir__)
    has_screenshots = Dir.glob(File.join(screenshots_dir, "**", "*.{png,jpg,jpeg,PNG,JPG,JPEG}")).any?
    unless has_screenshots
      UI.important("No local screenshots in #{screenshots_dir} — uploading metadata only and leaving existing App Store screenshots untouched.")
    end

    # Screenshots-only mode: refresh App Store screenshots without touching the
    # (already-synced) 50-locale text metadata on the draft.
    screenshots_only = ENV["ASC_SCREENSHOTS_ONLY"] == "1"
    if screenshots_only && !has_screenshots
      UI.user_error!("ASC_SCREENSHOTS_ONLY=1 but no local screenshots found in #{screenshots_dir}")
    end

    deliver(
      api_key: api_key,
      app_version: version,
      skip_app_version_update: true,
      force: true,
      ignore_language_directory_validation: true,
      precheck_include_in_app_purchases: false,
      version_check_wait_retry_limit: 7,
      skip_binary_upload: true,
      skip_metadata: screenshots_only,
      skip_screenshots: !has_screenshots,
      overwrite_screenshots: has_screenshots,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end
